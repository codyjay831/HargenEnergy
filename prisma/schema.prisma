// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "client"
  output      = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CLIENT
}

enum ClientStatus {
  LEAD
  ACTIVE
  PAUSED
  CANCELLED
}

enum PlanType {
  LIGHT
  CORE
  PRIORITY
  CUSTOM
}

enum Urgency {
  NORMAL
  THIS_WEEK
  URGENT
  ONGOING
}

enum RequestStatus {
  NEW
  REVIEWED
  IN_PROGRESS
  NEEDS_INFO
  WAITING_ON_CUSTOMER
  WAITING_ON_THIRD_PARTY
  COMPLETE
  CANCELLED
}

enum BillableType {
  INCLUDED
  OVERFLOW
  NON_BILLABLE
}

enum OverflowStatus {
  NOT_NEEDED
  NEEDS_APPROVAL
  APPROVED
  DECLINED
  DEFERRED
}

enum AuthorType {
  ADMIN
  CLIENT
  SYSTEM
}

model User {
  id           String      @id @default(cuid())
  name         String?
  email        String      @unique
  passwordHash String
  /** Monotonic-ish marker: sessions minted with an older stamp are invalid after password change/reset. */
  passwordChangedAt DateTime @default(now())
  role         Role        @default(CLIENT)
  clientId     String?
  client       Client?     @relation(fields: [clientId], references: [id])
  timeEntries  TimeEntry[] @relation("TimeEntryCreator")
  approvedOverflows SupportRequest[] @relation("OverflowApprover")
  comments     RequestComment[]
  passwordResetTokens PasswordResetToken[]
  outreachActivities OutreachActivity[]
  outreachSearchRuns OutreachSearchRun[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Client {
  id                 String           @id @default(cuid())
  companyName        String
  contactName        String
  email              String
  phone              String?
  website            String?
  serviceArea        String?
  role               String?
  currentTools       String?
  status             ClientStatus     @default(LEAD)
  planType           PlanType         @default(LIGHT)
  weeklyHours        Float            @default(0)
  stripeCustomerId   String?
  stripeSubscriptionId String?
  subscriptionStatus String?
  subscriptionCurrentPeriodEnd DateTime?
  notes              String?
  users              User[]
  requests           SupportRequest[]
  timeEntries        TimeEntry[]
  attachments        Attachment[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model SupportRequest {
  id                  String        @id @default(cuid())
  clientId            String
  client              Client        @relation(fields: [clientId], references: [id])
  title               String
  requestType         String?
  supportNeeded       String?
  description         String
  mostHelpful         String?
  urgency             Urgency       @default(NORMAL)
  status              RequestStatus @default(NEW)
  needsInfo           Boolean       @default(false)
  clientVisibleUpdate String?
  internalNotes       String?
  estimatedMinutes    Int?
  overflowStatus      OverflowStatus @default(NOT_NEEDED)
  overflowReason      String?
  overflowApprovedAt  DateTime?
  overflowApprovedById String?
  overflowApprovedBy   User?          @relation("OverflowApprover", fields: [overflowApprovedById], references: [id])
  deferredUntil       DateTime?
  priorityRank        Int?
  completedAt         DateTime?
  timeEntries         TimeEntry[]
  attachments         Attachment[]
  comments            RequestComment[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model RequestComment {
  id               String         @id @default(cuid())
  supportRequestId String
  supportRequest   SupportRequest @relation(fields: [supportRequestId], references: [id])
  authorUserId     String?
  authorUser       User?          @relation(fields: [authorUserId], references: [id])
  authorType       AuthorType
  body             String
  isInternal       Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model TimeEntry {
  id               String         @id @default(cuid())
  clientId         String
  client           Client         @relation(fields: [clientId], references: [id])
  supportRequestId String?
  supportRequest   SupportRequest? @relation(fields: [supportRequestId], references: [id])
  date             DateTime       @default(now())
  minutes          Int
  description      String
  billableType     BillableType   @default(INCLUDED)
  createdById      String?
  createdBy        User?          @relation("TimeEntryCreator", fields: [createdById], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Attachment {
  id               String          @id @default(cuid())
  clientId         String
  client           Client          @relation(fields: [clientId], references: [id])
  supportRequestId String?
  supportRequest   SupportRequest? @relation(fields: [supportRequestId], references: [id])
  fileName         String
  fileUrl          String
  fileType         String
  uploadedById     String?
  createdAt        DateTime        @default(now())
}

model SubscriptionPlan {
  id                 String   @id @default(cuid())
  name               String
  weeklyHours        Float
  monthlyPriceCents  Int?
  stripePriceId      String?
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
}

enum OutreachCompanyStatus {
  LEAD_FOUND
  CONTACTED
  FOLLOW_UP_NEEDED
  REPLIED
  INTERESTED
  CALL_BOOKED
  TRIAL_OFFERED
  WON
  NO_RESPONSE
  NOT_INTERESTED
  BAD_FIT
  DO_NOT_CONTACT
}

enum OutreachChannel {
  EMAIL
  WEBSITE_FORM
  LINKEDIN
  FACEBOOK
  PHONE
  TEXT
  IN_PERSON
  OTHER
}

enum OutreachActivityType {
  MESSAGE_SENT
  REPLY_RECEIVED
  FOLLOW_UP_SENT
  CALL_BOOKED
  CALL_COMPLETED
  PROPOSAL_SENT
  DECLINED
  NOTE
}

enum BusinessType {
  SOLAR_INSTALLER
  ELECTRICAL_CONTRACTOR
  ROOFING_SOLAR
  BATTERY_INSTALLER
  SOLAR_SERVICE_COMPANY
  OTHER
}

model OutreachCompany {
  id                 String                @id @default(cuid())
  name               String
  website            String?
  city               String?
  county             String?
  state              String?
  serviceArea        String?
  businessType       BusinessType?         @default(OTHER)
  companySizeEstimate String?
  leadSource         String?
  sourceQuery        String?
  sourceUrl          String?
  status             OutreachCompanyStatus @default(LEAD_FOUND)
  interestLevel      Int?                  @default(0) // 1-5 scale
  fitScore           Int?                  @default(0) // 1-5 scale
  notes              String?
  painTags           String[]              @default([])
  doNotContact       Boolean               @default(false)
  enrichmentData     Json?                 // For AI findings
  contacts           OutreachContact[]
  activities         OutreachActivity[]
  lastContactedAt    DateTime?
  nextFollowUpAt     DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([status])
  @@index([state, city])
}

model OutreachContact {
  id                 String           @id @default(cuid())
  companyId          String
  company            OutreachCompany  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name               String
  roleTitle          String?
  email              String?
  phone              String?
  linkedinUrl        String?
  facebookUrl        String?
  companyFacebookUrl String?
  websiteContactFormUrl String?
  preferredChannel   OutreachChannel?
  isPrimary          Boolean          @default(false)
  notes              String?
  activities         OutreachActivity[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([companyId])
}

model OutreachActivity {
  id                 String               @id @default(cuid())
  companyId          String
  company            OutreachCompany      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId          String?
  contact            OutreachContact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  date               DateTime             @default(now())
  channel            OutreachChannel
  activityType       OutreachActivityType
  templateUsed       String?
  messageSnapshot    String?
  notes              String?
  responseSummary    String?
  outcome            String?
  nextFollowUpAt     DateTime?
  createdById        String?
  createdBy          User?                @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt          DateTime             @default(now())

  @@index([companyId])
  @@index([date])
}

model OutreachTemplate {
  id           String          @id @default(cuid())
  name         String
  channel      OutreachChannel
  templateType String?         // e.g., "First Outreach", "Follow-up"
  subject      String?
  body         String
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

enum OutreachSearchSource {
  GOOGLE
  PERMITSTACK
}

enum OutreachSearchStatus {
  SUCCESS
  EMPTY
  ERROR
}

model OutreachSearchRun {
  id             String               @id @default(cuid())
  source         OutreachSearchSource
  createdById    String?
  createdBy      User?                @relation(fields: [createdById], references: [id], onDelete: SetNull)
  queryText      String?
  params         Json?
  resultCount    Int                  @default(0)
  searchMode     String?
  status         OutreachSearchStatus
  errorMessage   String?
  resultSnapshot Json?
  createdAt      DateTime             @default(now())

  @@index([createdAt])
  @@index([source, createdAt])
}
