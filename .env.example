# ==========================================
# REQUIRED FOR APP RUNTIME
# ==========================================
DATABASE_URL="postgresql://hargen:hargen_dev_password@localhost:5434/hargen_dev?schema=public"

# Generate a secret using: npx auth secret
AUTH_SECRET="your-auth-secret"

# The public URL of your application (used in email links, etc.)
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# ==========================================
# RATE LIMITING (RECOMMENDED FOR PRODUCTION)
# ==========================================
# Distributed limits for login, password reset, public intake, and admin setup.
# Create a Redis database at https://upstash.com and paste REST credentials.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Single-instance / local only: in-memory limiter (NOT safe across multiple app instances).
# Development uses in-memory automatically. For production single-node, set to "1" only if you accept that tradeoff.
RATE_LIMIT_ALLOW_MEMORY=""

# ==========================================
# REQUIRED FOR FIRST ADMIN SETUP
# ==========================================
# A high-entropy random string used by the one-time /setup/admin route.
# Generate with: openssl rand -hex 32   (or any strong random generator)
# Setup is only allowed when:
#   - ADMIN_SETUP_TOKEN is set, AND
#   - no ADMIN user exists yet in the database.
# After the first admin is created, the route automatically refuses further
# setup attempts. You may safely remove ADMIN_SETUP_TOKEN after setup.
ADMIN_SETUP_TOKEN=""


# ==========================================
# REQUIRED FOR EMAIL (RESEND)
# ==========================================
RESEND_API_KEY="re_xxxxxxxxx"
RESEND_FROM_EMAIL="no-reply@your-verified-domain.com"
RESEND_FROM_NAME="Hargen Energy Solar Ops Desk"
SUPPORT_NOTIFICATION_EMAIL="admin@hargenenergy.com"


# ==========================================
# REQUIRED FOR STRIPE
# ==========================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ==========================================
# REQUIRED FOR FILE UPLOADS (VERCEL BLOB)
# Server-only — auto-injected when a Blob store is linked on Vercel.
# Local: copy from Vercel Dashboard → Storage → your store → Read/Write token.
# ==========================================
BLOB_READ_WRITE_TOKEN=""

# ==========================================
# OPTIONAL — OUTREACH APIS
# ==========================================
GOOGLE_MAPS_API_KEY=""
GEMINI_API_KEY=""
YELP_API_KEY=""
PERMITSTACK_API_KEY=""
APOLLO_API_KEY=""
TRADES_API_KEY=""

# Price IDs for support blocks (Monthly Subscriptions)
STRIPE_LIGHT_PRICE_ID="price_..."
STRIPE_CORE_PRICE_ID="price_..."
STRIPE_PRIORITY_PRICE_ID="price_..."


# ==========================================
# OPTIONAL — MANUAL/LOCAL SEED ONLY
# ==========================================
# These are NOT required by production builds. The production build script no
# longer runs `prisma db seed`. They are only consumed by the optional
# `npm run prisma:seed` utility for local/dev convenience.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME=""


# ==========================================
# NOTES
# ==========================================
# 1. In production (e.g. Vercel), DATABASE_URL must be available during build and runtime.
# 2. Stripe live mode requires live Price IDs (starting with price_).
# 3. Resend sender domain should be verified in the Resend dashboard before production use.
# 4. AUTH_SECRET is mandatory for production builds.
# 5. The first admin should be created via /setup/admin using ADMIN_SETUP_TOKEN.
